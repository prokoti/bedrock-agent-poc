# Streamlit Cloud secrets template
# Copy these into the "Secrets" section of your app on share.streamlit.io
# (Settings -> Secrets). Do NOT commit real values.

AWS_REGION = "us-east-1"
AWS_ACCESS_KEY_ID = "AKIA..."
AWS_SECRET_ACCESS_KEY = "..."

# Supabase Postgres (from Project Settings -> Database -> Connection string)
DB_HOST = "db.xxxxxxxxxxxx.supabase.co"
DB_PORT = "5432"
DB_NAME = "postgres"
DB_USER = "postgres"
DB_PASSWORD = "your-supabase-password"

# OpenSearch
OPENSEARCH_URL = "https://your-collection.us-east-1.aoss.amazonaws.com"
OPENSEARCH_INDEX = "employee-knowledge"

# Bedrock Guardrails
GUARDRAIL_ID = "..."
GUARDRAIL_VERSION = "DRAFT"
